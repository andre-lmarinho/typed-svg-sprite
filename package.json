{
  "name": "typed-svg-sprite",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A type-safe SVG sprite icon system: one cached sprite, one <Icon name=\"...\"> with full autocomplete.",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:icons && tsc --noEmit && vite build",
    "preview": "vite preview",
    "build:icons": "node scripts/build-icons.mjs",
    "test:icons": "node --test scripts/build-icons.test.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-static": "^1.21.0",
    "typescript": "^5.6.3",
    "vite": "^7.1.0"
  }
}
